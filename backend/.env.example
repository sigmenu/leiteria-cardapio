# Server Configuration
PORT=3001
NODE_ENV=production

# JWT Configuration (IMPORTANTE: trocar por uma string aleatória longa)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# CORS Configuration
# Em desenvolvimento: http://localhost:5173
# Em produção: deixar vazio ou colocar o domínio do site
FRONTEND_URL=

# Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=uploads